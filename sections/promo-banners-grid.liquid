<div class="promo-banners-grid section-{{ section.id }}-padding" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background-color: var(--color-background);">
  <div class="page-width">
    <div class="promo-banners__container">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link | default: '#' }}" class="promo-banners__item" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.image.alt | escape }}" class="promo-banners__image" loading="lazy" width="800" height="auto">
          {% else %}
            <div class="promo-banners__placeholder">
              {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
              <div class="promo-banners__placeholder-text">
                <h3>{{ block.settings.heading | default: 'Promo Banner' }}</h3>
              </div>
            </div>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .promo-banners__container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  @media screen and (min-width: 750px) {
    .promo-banners__container {
      flex-direction: row;
      gap: 2rem;
    }
  }

  .promo-banners__item {
    flex: 1;
    display: block;
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .promo-banners__item:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
  }

  .promo-banners__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .promo-banners__placeholder {
    width: 100%;
    aspect-ratio: 16/9;
    background-color: #f4f4f4;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .promo-banners__placeholder .placeholder-svg {
    width: 100%;
    height: 100%;
    fill: #ccc;
  }

  .promo-banners__placeholder-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(0,0,0,0.7);
    color: #fff;
    padding: 1rem 2rem;
    border-radius: 4px;
    text-align: center;
  }

  .promo-banners__placeholder-text h3 {
    margin: 0;
    font-size: 1.5rem;
    color: #fff;
  }
</style>

{% schema %}
{
  "name": "Promo Banners Grid",
  "max_blocks": 4,
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Landscape images work best (e.g. 800x400px)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Banner Link"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Placeholder Heading",
          "default": "Shop Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo Banners Grid",
      "blocks": [
        { "type": "banner" },
        { "type": "banner" }
      ]
    }
  ]
}
{% endschema %}
