{{ 'aesthetic.css' | asset_url | stylesheet_tag }}

<div id="store-locator-section" class="store-locator-wrapper section-{{ section.id }}-padding" style="background-color: var(--color-background); padding-top: 4rem; padding-bottom: 4rem;">
  <div class="page-width">
    {% if section.settings.title != blank %}
      <h2 class="title inline-richtext text-center" style="margin-bottom: 3rem; font-family: var(--font-heading-family); text-transform: uppercase;">{{ section.settings.title }}</h2>
    {% endif %}

    <div class="store-locator-grid">
      
      <!-- Store List Sidebar -->
      <div class="store-locator-sidebar">
        {% for block in section.blocks %}
          {% if block.type == 'store' %}
            <div class="store-card" onclick="highlightStore({{ forloop.index0 }})" {{ block.shopify_attributes }}>
              <h3 class="store-card__name">{{ block.settings.store_name }}</h3>
              <p class="store-card__text">{{ block.settings.address | newline_to_br }}</p>
              {% if block.settings.phone != blank %}
                <p class="store-card__text"><strong>Phone:</strong> {{ block.settings.phone }}</p>
              {% endif %}
              {% if block.settings.hours != blank %}
                <p class="store-card__text"><strong>Hours:</strong> {{ block.settings.hours }}</p>
              {% endif %}
            </div>
          {% endif %}
        {% else %}
          <p>No stores added yet. Please add store blocks in the Theme Editor.</p>
        {% endfor %}
      </div>

      <!-- Map Display -->
      <div class="store-locator-map-container">
        {% if section.settings.map_embed_code != blank %}
          <div class="map-embed">
            {{ section.settings.map_embed_code }}
          </div>
        {% else %}
          <div class="map-embed">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3719.761263093412!2d72.79469297504889!3d21.201640780491314!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3be04d800fb385b1%3A0x41726302b5e31aa5!2sSai%20SHOES..!5e0!3m2!1sen!2sin!4v1777629859580!5m2!1sen!2sin"
              width="100%"
              height="600"
              style="border:0; display:block;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="SAI SHOES Store Location"
            ></iframe>
          </div>
        {% endif %}
      </div>

    </div>
  </div>
</div>

<style>
  .store-locator-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media screen and (min-width: 750px) {
    .store-locator-grid {
      grid-template-columns: 1fr 2fr;
    }
  }
  .store-locator-sidebar {
    max-height: 600px;
    overflow-y: auto;
    padding-right: 1rem;
  }
  
  /* Scrollbar styles for the sidebar */
  .store-locator-sidebar::-webkit-scrollbar {
    width: 6px;
  }
  .store-locator-sidebar::-webkit-scrollbar-track {
    background: rgb(var(--color-foreground-rgb) / 0.05);
  }
  .store-locator-sidebar::-webkit-scrollbar-thumb {
    background: rgb(var(--color-foreground-rgb) / 0.2);
    border-radius: 4px;
  }
  
  .store-card {
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.2);
    padding: 1.5rem;
    margin-bottom: 1rem;
    cursor: pointer;
    transition: all 0.2s ease;
    background-color: var(--color-background);
  }
  .store-card:hover, .store-card.is-active {
    background-color: rgb(var(--color-foreground-rgb) / 0.05);
    border-color: rgb(var(--color-foreground-rgb));
  }
  .store-card__name {
    margin-top: 0;
    font-size: 1.5rem;
    font-weight: bold;
    text-transform: uppercase;
    margin-bottom: 1rem;
    color: var(--color-foreground);
  }
  .store-card__text {
    margin-bottom: 0.5rem;
    opacity: 0.8;
    color: var(--color-foreground);
    line-height: 1.4;
  }
  .store-card__text:last-child {
    margin-bottom: 0;
  }
  
  .store-locator-map-container {
    background: rgb(var(--color-foreground-rgb) / 0.05);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.2);
    min-height: 400px;
    position: relative;
    overflow: hidden;
  }
  .map-embed {
    width: 100%;
    height: 100%;
  }
  .store-locator-map-container iframe {
    width: 100% !important;
    height: 100% !important;
    min-height: 600px;
    border: none;
    display: block;
  }
  .map-placeholder {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    opacity: 0.5;
    color: var(--color-foreground);
  }
</style>

<script>
  function highlightStore(index) {
    const cards = document.querySelectorAll('.store-card');
    cards.forEach(card => card.classList.remove('is-active'));
    cards[index].classList.add('is-active');
  }
</script>

{% schema %}
{
  "name": "Store Locator",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Find Our Stores"
    },
    {
      "type": "textarea",
      "id": "map_embed_code",
      "label": "Google Maps Embed Code",
      "info": "Go to Google Maps, find your store or general area, click Share > Embed a map, and paste the iframe HTML here."
    }
  ],
  "blocks": [
    {
      "type": "store",
      "name": "Store Location",
      "settings": [
        {
          "type": "text",
          "id": "store_name",
          "label": "Store Name",
          "default": "RedTape Flagship"
        },
        {
          "type": "textarea",
          "id": "address",
          "label": "Address",
          "default": "123 Main Street\nNew Delhi, India"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone Number",
          "default": "+91 9876543210"
        },
        {
          "type": "text",
          "id": "hours",
          "label": "Operating Hours",
          "default": "Mon-Sun: 10AM - 9PM"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store Locator",
      "blocks": [
        {
          "type": "store"
        },
        {
          "type": "store"
        }
      ]
    }
  ]
}
{% endschema %}
