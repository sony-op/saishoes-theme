<div class="skechers-footer" style="background-color: {{ section.settings.bg_color }};">
  
  {% if section.settings.show_popular_searches %}
  <div class="skechers-footer-top">
    <div class="footer-container">
      <h4 class="popular-searches-title">{{ section.settings.popular_searches_title }}</h4>
      <div class="popular-searches-links">
        {{ section.settings.popular_searches_text }}
      </div>
    </div>
  </div>
  {% endif %}

  <div class="skechers-footer-main">
    <div class="footer-container">
      <div class="footer-main-grid">
        
        <div class="footer-menus">
          {% for block in section.blocks %}
            {% if block.type == 'menu' %}
              <div class="footer-menu-col">
                {% if forloop.first and section.settings.footer_logo != blank %}
                  <div class="footer-logo">
                    <img src="{{ section.settings.footer_logo | image_url: width: 300 }}" alt="{{ shop.name }}" loading="lazy" width="150" height="auto">
                  </div>
                {% endif %}
                <h4 class="footer-menu-title">{{ block.settings.title }}</h4>
                {% if block.settings.menu != blank %}
                  <ul class="footer-menu-list">
                    {% for link in block.settings.menu.links %}
                      <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>

        <div class="footer-social">
          <h4 class="footer-social-title">{{ section.settings.social_title }}</h4>
          <div class="social-icons">
            {% if settings.social_facebook_link != blank %}
              <a href="{{ settings.social_facebook_link }}" class="social-icon">{% render 'icon-facebook' %}</a>
            {% else %}
              <a href="#" class="social-icon"><svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.879V14.89h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.989C18.343 21.129 22 16.99 22 12c0-5.523-4.477-10-10-10z"></path></svg></a>
            {% endif %}
            
            {% if settings.social_twitter_link != blank %}
              <a href="{{ settings.social_twitter_link }}" class="social-icon">{% render 'icon-twitter' %}</a>
            {% else %}
              <a href="#" class="social-icon"><svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.05c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z"></path></svg></a>
            {% endif %}
            
            {% if settings.social_instagram_link != blank %}
              <a href="{{ settings.social_instagram_link }}" class="social-icon">{% render 'icon-instagram' %}</a>
            {% else %}
              <a href="#" class="social-icon"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg></a>
            {% endif %}
            
            {% if settings.social_youtube_link != blank %}
              <a href="{{ settings.social_youtube_link }}" class="social-icon">{% render 'icon-youtube' %}</a>
            {% else %}
               <a href="#" class="social-icon"><svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M21.582 6.186a2.67 2.67 0 0 0-1.884-1.884C18.04 3.84 12 3.84 12 3.84s-6.04 0-7.698.462a2.67 2.67 0 0 0-1.884 1.884C1.956 7.844 1.956 12 1.956 12s0 4.156.462 5.814a2.67 2.67 0 0 0 1.884 1.884C5.96 20.16 12 20.16 12 20.16s6.04 0 7.698-.462a2.67 2.67 0 0 0 1.884-1.884C22.044 16.156 22.044 12 22.044 12s0-4.156-.462-5.814zM9.963 15.48V8.52L15.96 12l-5.997 3.48z"></path></svg></a>
            {% endif %}
          </div>
        </div>

      </div>
    </div>
  </div>

</div>

{% schema %}
{
  "name": "Skechers Footer",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f8f8f8"
    },
    {
      "type": "header",
      "content": "Popular Searches"
    },
    {
      "type": "checkbox",
      "id": "show_popular_searches",
      "label": "Show Popular Searches",
      "default": true
    },
    {
      "type": "text",
      "id": "popular_searches_title",
      "label": "Title",
      "default": "POPULAR SEARCHES"
    },
    {
      "type": "richtext",
      "id": "popular_searches_text",
      "label": "Text (use | as separator)",
      "default": "<p>Women's Shoes | Walking Shoes for Women | Walking Shoes for Men | Men's Shoes | Running Shoes for Women | Running Shoes for Men | Women's Slippers | Men's Slippers | Kids Shoes | Slip-Ins | Men's Jackets | Women's Jacket | Men's T-Shirts | Sports Bra | Arch Fit Shoes | Memory Foam | Goga Mat | GO Walk | James Gold Crown Collection | GO Run | Mark Nason | Kids Light Up Shoes | Tokidoki | Shoes Sale | Running Shoes | Walking Shoes | Trail-Hiking | Black Shoes | White Shoes | Pink Shoes | Blue Shoes |</p>"
    },
    {
      "type": "header",
      "content": "Main Footer"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer Logo"
    },
    {
      "type": "text",
      "id": "social_title",
      "label": "Social Media Title",
      "default": "Follow us"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu Column",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Menu Title"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Skechers Footer",
      "blocks": [
        { "type": "menu", "settings": { "title": "About Skechers" } },
        { "type": "menu", "settings": { "title": "Customer Service" } },
        { "type": "menu", "settings": { "title": "My Account" } },
        { "type": "menu", "settings": { "title": "Others" } }
      ]
    }
  ]
}
{% endschema %}
