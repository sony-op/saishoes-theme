<style>
  /* ==========================================
     GOOGLE REVIEWS SECTION
  ========================================== */
  .google-reviews-section {
    background: #ffffff;
    padding: 60px 20px;
    font-family: var(--font-body-family, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif);
    overflow: hidden;
    border-top: 4px solid #111;
    border-bottom: 1px solid #e8e8e8;
  }

  .google-reviews-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 30px;
    margin-bottom: 40px;
    flex-wrap: wrap;
    text-align: center;
  }

  .google-reviews-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .google-reviews-brand h2 {
    font-size: 28px;
    font-weight: 700;
    color: #111;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .google-reviews-overall {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 20px 30px;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.07);
    min-width: 160px;
  }

  .google-reviews-score {
    font-size: 52px;
    font-weight: 800;
    color: #111;
    line-height: 1;
  }

  .google-stars {
    display: flex;
    gap: 3px;
  }

  .google-stars svg {
    width: 20px;
    height: 20px;
  }

  .google-reviews-count {
    font-size: 13px;
    color: #888;
    margin: 0;
  }

  .google-reviews-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: #555;
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 30px;
    padding: 8px 16px;
  }

  .google-reviews-badge svg {
    flex-shrink: 0;
  }

  /* Carousel */
  .google-reviews-carousel-wrapper {
    position: relative;
    max-width: 1300px;
    margin: 0 auto;
  }

  .google-reviews-track-outer {
    overflow: hidden;
  }

  .google-reviews-track {
    display: flex;
    gap: 20px;
    transition: transform 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  /* Review Card */
  .google-review-card {
    background: #fff;
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    min-width: 300px;
    max-width: 300px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
    border: 1px solid #f0f0f0;
  }

  .google-review-card:hover {
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    transform: translateY(-4px);
  }

  .google-review-card__header {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .google-review-card__avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
    background: #4285F4;
  }

  .google-review-card__info {
    flex: 1;
    min-width: 0;
  }

  .google-review-card__name {
    font-size: 14px;
    font-weight: 700;
    color: #111;
    margin: 0 0 2px 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .google-review-card__date {
    font-size: 12px;
    color: #999;
    margin: 0;
  }

  .google-review-card__google-icon {
    flex-shrink: 0;
  }

  .google-review-card__stars {
    display: flex;
    gap: 2px;
  }

  .google-review-card__stars svg {
    width: 16px;
    height: 16px;
  }

  .google-review-card__text {
    font-size: 14px;
    color: #444;
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .google-review-card__footer {
    margin-top: auto;
  }

  /* Nav Arrows */
  .google-reviews-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
    margin-top: 30px;
  }

  .google-reviews-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1.5px solid #ddd;
    background: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    color: #333;
  }

  .google-reviews-btn:hover {
    background: #111;
    border-color: #111;
    color: #fff;
  }

  .google-reviews-btn svg {
    width: 18px;
    height: 18px;
  }

  .google-reviews-dots {
    display: flex;
    gap: 6px;
  }

  .google-reviews-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #ddd;
    cursor: pointer;
    transition: background 0.3s, width 0.3s;
    border: none;
    padding: 0;
  }

  .google-reviews-dot.is-active {
    background: #111;
    width: 24px;
    border-radius: 4px;
  }

  /* Write a Review CTA */
  .google-reviews-cta {
    text-align: center;
    margin-top: 36px;
  }

  .google-reviews-cta a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    border: 1.5px solid #111;
    color: #111;
    font-weight: 700;
    font-size: 14px;
    padding: 12px 28px;
    border-radius: 30px;
    text-decoration: none;
    transition: all 0.3s ease;
    letter-spacing: 0.5px;
  }

  .google-reviews-cta a:hover {
    background: #111;
    color: #fff;
  }

  @media screen and (max-width: 768px) {
    .google-reviews-section {
      padding: 40px 16px;
    }

    .google-reviews-header {
      gap: 16px;
    }

    .google-reviews-score {
      font-size: 40px;
    }

    .google-review-card {
      min-width: 270px;
      max-width: 270px;
    }
  }
</style>

{% assign place_id = section.settings.place_id | default: 'ChIJsYWzD4BN4DsRpRrjtQJjckE' %}
{% assign review_url = 'https://search.google.com/local/writereview?placeid=' | append: place_id %}

<div class="google-reviews-section" id="google-reviews-section">
  <div class="google-reviews-header">
    <div class="google-reviews-brand">
      <h2>{{ section.settings.business_name | default: shop.name }}</h2>
    </div>

    <div class="google-reviews-overall">
      <div class="google-reviews-score">{{ section.settings.overall_rating | default: '4.8' }}</div>
      <div class="google-stars">
        {% assign rating = section.settings.overall_rating | default: '4.8' | times: 1 %}
        {% for i in (1..5) %}
          {% if i <= rating %}
            <svg viewBox="0 0 24 24" fill="#FBBC04"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {% else %}
            <svg viewBox="0 0 24 24" fill="#e0e0e0"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {% endif %}
        {% endfor %}
      </div>
      <p class="google-reviews-count">{{ section.settings.review_count | default: '120' }}+ Google Reviews</p>
    </div>

    <div class="google-reviews-badge">
      <!-- Google G Logo -->
      <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Verified Google Reviews
    </div>
  </div>

  <div class="google-reviews-carousel-wrapper">
    <div class="google-reviews-track-outer">
      <div class="google-reviews-track" id="reviewsTrack">
        {% for block in section.blocks %}
          {% assign colors = '#4285F4,#EA4335,#34A853,#FBBC04,#9C27B0,#FF5722' | split: ',' %}
          {% assign color_index = forloop.index0 | modulo: 6 %}
          {% assign avatar_color = colors[color_index] %}
          {% assign initial = block.settings.reviewer_name | slice: 0 | upcase %}

          <div class="google-review-card" {{ block.shopify_attributes }}>
            <div class="google-review-card__header">
              <div class="google-review-card__avatar" style="background: {{ avatar_color }};">
                {{ initial }}
              </div>
              <div class="google-review-card__info">
                <p class="google-review-card__name">{{ block.settings.reviewer_name | default: 'Customer' }}</p>
                <p class="google-review-card__date">{{ block.settings.review_date | default: 'a week ago' }}</p>
              </div>
              <div class="google-review-card__google-icon">
                <svg width="18" height="18" viewBox="0 0 24 24">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
              </div>
            </div>

            <div class="google-review-card__stars">
              {% assign star_count = block.settings.star_rating | default: 5 %}
              {% for i in (1..5) %}
                {% if i <= star_count %}
                  <svg viewBox="0 0 24 24" fill="#FBBC04"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {% else %}
                  <svg viewBox="0 0 24 24" fill="#e0e0e0"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {% endif %}
              {% endfor %}
            </div>

            <p class="google-review-card__text">{{ block.settings.review_text }}</p>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="google-reviews-nav">
      <button class="google-reviews-btn" id="reviewsPrev" aria-label="Previous reviews">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <div class="google-reviews-dots" id="reviewsDots"></div>
      <button class="google-reviews-btn" id="reviewsNext" aria-label="Next reviews">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>

  <div class="google-reviews-cta">
    <a href="{{ review_url }}" target="_blank" rel="noopener">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      Write a Review on Google
    </a>
  </div>
</div>

<script>
  (function() {
    const track = document.getElementById('reviewsTrack');
    const dotsContainer = document.getElementById('reviewsDots');
    const prevBtn = document.getElementById('reviewsPrev');
    const nextBtn = document.getElementById('reviewsNext');

    if (!track) return;

    const cards = track.querySelectorAll('.google-review-card');
    const cardCount = cards.length;
    let current = 0;

    function getVisible() {
      return window.innerWidth < 768 ? 1 : window.innerWidth < 1100 ? 2 : 3;
    }

    function totalPages() {
      return Math.ceil(cardCount / getVisible());
    }

    function buildDots() {
      dotsContainer.innerHTML = '';
      const pages = totalPages();
      for (let i = 0; i < pages; i++) {
        const dot = document.createElement('button');
        dot.className = 'google-reviews-dot' + (i === current ? ' is-active' : '');
        dot.setAttribute('aria-label', 'Go to page ' + (i + 1));
        dot.addEventListener('click', () => goTo(i));
        dotsContainer.appendChild(dot);
      }
    }

    function updateDots() {
      dotsContainer.querySelectorAll('.google-reviews-dot').forEach((dot, i) => {
        dot.classList.toggle('is-active', i === current);
      });
    }

    function goTo(index) {
      const pages = totalPages();
      current = Math.max(0, Math.min(index, pages - 1));
      const cardWidth = cards[0].offsetWidth + 20; // card + gap
      track.style.transform = 'translateX(-' + (current * getVisible() * cardWidth) + 'px)';
      updateDots();
    }

    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));

    window.addEventListener('resize', () => {
      current = 0;
      buildDots();
      goTo(0);
    });

    buildDots();
  })();
</script>

