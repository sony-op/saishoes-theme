{{ 'aesthetic.css' | asset_url | stylesheet_tag }}

<div class="category-carousel-wrapper section-{{ section.id }}-padding" style="background-color: var(--color-background); padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    {% if section.settings.title != blank %}
      <h2 class="title inline-richtext text-center" style="margin-bottom: 2.5rem; font-family: var(--font-heading-family); text-transform: uppercase;">{{ section.settings.title }}</h2>
    {% endif %}

    <div class="category-carousel-scroll">
      <div class="category-grid">
        {% for block in section.blocks %}
          <a href="{{ block.settings.link | default: '#' }}" class="category-card" {{ block.shopify_attributes }}>
            <div class="category-card__image-wrapper">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.title | escape }}" class="category-card__image" loading="lazy" width="200" height="200">
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg category-card__image' }}
              {% endif %}
            </div>
            {% if block.settings.title != blank %}
              <h3 class="category-card__title">{{ block.settings.title }}</h3>
            {% endif %}
          </a>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<style>
  .category-carousel-scroll {
    width: 100%;
    overflow-x: auto;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none;  /* IE and Edge */
    padding-bottom: 1.5rem;
    -webkit-overflow-scrolling: touch; /* Smooth scrolling on iOS */
  }
  .category-carousel-scroll::-webkit-scrollbar {
    display: none; /* Chrome, Safari and Opera */
  }

  .category-grid {
    display: flex;
    gap: 1.5rem;
    min-width: min-content;
    padding: 0 1rem;
  }

  @media screen and (min-width: 750px) {
    .category-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 2.5rem 1.5rem;
      padding: 0;
      justify-content: center;
    }
    .category-carousel-scroll {
      overflow-x: visible;
    }
  }

  .category-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    flex: 0 0 auto;
    width: 120px;
    transition: transform 0.2s ease;
  }
  @media screen and (min-width: 750px) {
    .category-card {
      width: 100%;
    }
  }
  .category-card:hover {
    transform: translateY(-5px);
  }

  .category-card__image-wrapper {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 16px; /* Rounded corners like the screenshot */
    overflow: hidden;
    background-color: #f4f4f4;
    margin-bottom: 0.75rem;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    position: relative;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.05);
  }

  .category-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
    transition: transform 0.3s ease;
  }
  
  .category-card:hover .category-card__image {
    transform: scale(1.05);
  }

  .placeholder-svg {
    padding: 1.5rem;
    background-color: #f4f4f4;
    fill: #ccc;
  }

  .category-card__title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-foreground);
    text-align: center;
    margin: 0;
    line-height: 1.3;
    font-family: var(--font-body-family);
  }
</style>

{% schema %}
{
  "name": "Shop By Category",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop By Category"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image",
          "info": "Upload a square image for best results."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category Name",
          "default": "Best Seller"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop By Category",
      "blocks": [
        { "type": "category", "settings": { "title": "Best Seller" } },
        { "type": "category", "settings": { "title": "New Arrivals" } },
        { "type": "category", "settings": { "title": "Trekking Shoes" } },
        { "type": "category", "settings": { "title": "Men's Sneakers" } },
        { "type": "category", "settings": { "title": "Women's Sneakers" } },
        { "type": "category", "settings": { "title": "Kid's Sneakers" } }
      ]
    }
  ]
}
{% endschema %}
