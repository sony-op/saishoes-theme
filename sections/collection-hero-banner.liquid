<div class="collection-hero-banner section-{{ section.id }}-padding" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="collection-hero__inner">
    {%- if section.settings.show_collection_image and collection.image -%}
      <div class="collection-hero__image-container">
        <img src="{{ collection.image | image_url: width: 2000 }}" alt="{{ collection.title | escape }}" class="collection-hero__image" loading="eager" width="2000" height="auto">
        <div class="collection-hero__overlay" style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
      </div>
    {%- elsif section.settings.fallback_image != blank -%}
      <div class="collection-hero__image-container">
        <img src="{{ section.settings.fallback_image | image_url: width: 2000 }}" alt="{{ collection.title | escape }}" class="collection-hero__image" loading="eager" width="2000" height="auto">
        <div class="collection-hero__overlay" style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
      </div>
    {%- else -%}
      <div class="collection-hero__image-container collection-hero__image-container--fallback">
         <!-- No image state -->
      </div>
    {%- endif -%}

    <div class="collection-hero__content-box">
      <h1 class="collection-hero__title" style="color: {{ section.settings.text_color }};">
        {{ collection.title | escape }}
      </h1>
      {%- if section.settings.show_collection_description and collection.description != blank -%}
        <div class="collection-hero__description rte" style="color: {{ section.settings.text_color }};">
          {{ collection.description }}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  .collection-hero__inner {
    position: relative;
    width: 100%;
    min-height: 40vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    overflow: hidden;
  }
  
  @media screen and (min-width: 750px) {
    .collection-hero__inner {
      min-height: 50vh;
    }
  }

  .collection-hero__image-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .collection-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .collection-hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
  }

  .collection-hero__content-box {
    position: relative;
    z-index: 3;
    text-align: center;
    padding: 2rem;
    max-width: 1000px;
    width: 100%;
  }

  .collection-hero__title {
    font-family: var(--font-heading-family);
    font-size: clamp(3rem, 6vw, 6rem);
    font-weight: 900;
    text-transform: uppercase;
    margin: 0;
    letter-spacing: 2px;
    line-height: 1.1;
    text-shadow: 0 4px 20px rgba(0,0,0,0.5);
  }

  .collection-hero__description {
    font-size: clamp(1rem, 2vw, 1.25rem);
    margin-top: 1rem;
    text-shadow: 0 2px 10px rgba(0,0,0,0.6);
    font-weight: 500;
  }
</style>

{% schema %}
{
  "name": "Collection Hero Banner",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "default": true,
      "label": "Show collection image",
      "info": "Uses the collection's featured image as the banner background."
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "Fallback image",
      "info": "Image to display if the collection doesn't have a featured image."
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "default": true,
      "label": "Show collection description"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Image overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Image overlay opacity",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Collection Hero Banner"
    }
  ]
}
{% endschema %}
